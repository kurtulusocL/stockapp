@model AppUserGetDto
@{
	ViewData["Title"] = "User Home";
	ViewData["Subtitle"] = "Manage your profile";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-3">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<div>
			<h2 class="fw-bold mb-1">@ViewData["Title"]</h2>
			<p class="text-muted mb-0">@ViewData["Subtitle"]</p>
		</div>
	</div>
	<div class="row g-4">
		<div class="col-md-8">
			<div class="card shadow-sm">
				<div class="card-header bg-white py-3">
					<h6 class="fw-bold mb-0">User Information</h6>
				</div>
				<div class="card-body">
					<dl class="row mb-0">
						<dt class="col-sm-3 text-muted fw-normal">Name Surname</dt>
						<dd class="col-sm-9 fw-semibold">@Model.NameSurname</dd>

						<dt class="col-sm-3 text-muted fw-normal">Email Address</dt>
						<dd class="col-sm-9">@Model.Email</dd>

						<dt class="col-sm-3 text-muted fw-normal">Username</dt>
						<dd class="col-sm-9">@Model.UserName</dd>

						<dt class="col-sm-3 text-muted fw-normal">Title</dt>
						<dd class="col-sm-9">@Model.Title</dd>

						<dt class="col-sm-3 text-muted fw-normal">Phone Number</dt>
						<dd class="col-sm-9">@Model.PhoneNumber</dd>

						<dt class="col-sm-3 text-muted fw-normal">Audits</dt>
						<dd class="col-sm-9">@Model.AuditCount</dd>

						<dt class="col-sm-3 text-muted fw-normal">Stock Movements</dt>
						<dd class="col-sm-9">@Model.StockMovementCount</dd>

						<dt class="col-sm-3 text-muted fw-normal">Products</dt>
						<dd class="col-sm-9">@Model.ProductCount</dd>

						<dt class="col-sm-3 text-muted fw-normal">Stocks</dt>
						<dd class="col-sm-9">@Model.UnitInStockCount</dd>

						<dt class="col-sm-3 text-muted fw-normal">Sessions</dt>
						<dd class="col-sm-9">@Model.UserSessionCount</dd>

						<dt class="col-sm-3 text-muted fw-normal">Status</dt>
						<dd class="col-sm-9">
							@if (Model.IsActive)
							{
								<span class="badge bg-success-subtle text-success px-3 py-2">Active</span>
							}
							else
							{
								<span class="badge bg-danger-subtle text-danger px-3 py-2">Inactive</span>
							}
							@if (Model.IsDeleted)
							{
								<span class="badge bg-success-subtle text-danger px-3 py-2">Deleted</span>
							}
							else
							{
								<span class="badge bg-danger-subtle text-success px-3 py-2">Not Deleted</span>
							}
						</dd>

						<dt class="col-sm-3 text-muted fw-normal">Login Code Status</dt>
						<dd class="col-sm-9">
							@if (Model.IsLoginConfirmCodeActive)
							{
								<span class="badge bg-success-subtle text-success px-3 py-2">Active</span>
							}
							else
							{
								<span class="badge bg-danger-subtle text-danger px-3 py-2">Inactive</span>
							}
						</dd>

						<dt class="col-sm-3 text-muted fw-normal">Created At</dt>
						<dd class="col-sm-9">@Model.CreatedDate.ToString("dd MMM yyyy, HH:mm")</dd>

						<dt class="col-sm-3 text-muted fw-normal">Updated At</dt>
						<dd class="col-sm-9">
							@(Model.UpdatedDate.HasValue? Model.UpdatedDate.Value.ToString("dd MMM yyyy, HH:mm") : "-")
						</dd>

						<dt class="col-sm-3 text-muted fw-normal">Suspended At</dt>
						<dd class="col-sm-9">
							@(Model.SuspendedDate.HasValue? Model.SuspendedDate.Value.ToString("dd MMM yyyy, HH:mm") : "-")
						</dd>

						<dt class="col-sm-3 text-muted fw-normal">Deleted At</dt>
						<dd class="col-sm-9">
							@(Model.DeletedDate.HasValue? Model.DeletedDate.Value.ToString("dd MMM yyyy, HH:mm") : "-")
						</dd>
					</dl>
				</div>
			</div>
		</div>
		<div class="col-md-4">
			<div class="card shadow-sm">
				<div class="card-header bg-white py-3">
					<h6 class="fw-bold mb-0">Actions</h6>
				</div>
				<div class="card-body d-grid gap-2">
					<a asp-controller="Account" asp-action="ResetPassword" class="btn btn-outline-primary">
						<i class="bi bi-pencil me-2"></i> Reset Password
					</a>
					<a asp-controller="Account" asp-action="UpdateProfile" class="btn btn-outline-success">
						<i class="bi bi-pencil me-2"></i> Update Profile
					</a>
					<a asp-controller="Account" asp-action="ChangePassword" class="btn btn-outline-dark">
						<i class="bi bi-pencil me-2"></i> Change Password
					</a>
					@if (Model.IsLoginConfirmCodeActive)
					{
						<span class="badge bg-success-subtle text-warning px-3 py-2">Login Code Active</span>
						<form asp-controller="User" asp-action="SetLoginCodeInActive" method="post" class="d-inline">
							@Html.AntiForgeryToken()							
							<button type="submit" class="btn btn-sm btn-warning">Set Inactive</button>
						</form>
					}
					else
					{
						<span class="badge bg-danger-subtle text-warning px-3 py-2">Login Code Inactive</span>
						<form asp-controller="User" asp-action="SetLoginCodeActive" method="post" class="d-inline">
							@Html.AntiForgeryToken()
							<button type="submit" class="btn btn-sm btn-warning">Set Active</button>
						</form>
					}
				</div>
			</div>
		</div>
	</div>
</div>