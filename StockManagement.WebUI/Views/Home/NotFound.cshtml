@{
    Layout = null;
    ViewData["Title"] = "404 - Page Not Found";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link href="~/css/errorpage.css" rel="stylesheet" />
</head>
<body>
    <div class="error-card">
        <div class="error-code not-found">404</div>
        <div class="error-title">Page Not Found</div>
        <p class="error-desc">The page you are looking for may not be available or may have moved.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4 py-2">Go to Home</a>
    </div>
</body>
</html>