@model LoginDto
@{
	ViewData["Title"] = "Login";
	Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Login</title>
	<link href="~/css/login.css" rel="stylesheet" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />	
</head>
<body>
	<div class="auth-card">
		<div class="auth-logo">
			<i class="bi bi-box-seam"></i>
		</div>
		<h1 class="auth-title">@ViewData["Title"]</h1>
		@if (ViewBag.Error != null)
		{
			<div class="alert alert-danger d-flex align-items-center gap-2 py-2 px-3 mb-3" style="font-size:0.875rem;">
				<i class="bi bi-exclamation-circle-fill"></i>
				@ViewBag.Error
			</div>
		}
		@using (Html.BeginForm("Login", "Account", FormMethod.Post, new { ReturnUrl = ViewBag.ReturnUrl }))
		{
			@Html.AntiForgeryToken()
			<div class="mb-3">
				<label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
				<input type="email" asp-for="Email" name="Email" class="form-control" placeholder="example@mail.com" required />
				<span asp-validation-for="Email" class="text-danger small"></span>
			</div>
			<div class="mb-3">
				<label asp-for="Password" class="form-label">Password <span class="text-danger">*</span></label>
				<div class="input-group">
					<input type="password" asp-for="Password" name="Password" id="passwordInput" class="form-control" placeholder="••••••••" required />
					<span class="input-group-text" onclick="togglePassword()">
						<i class="bi bi-eye" id="eyeIcon"></i>
					</span>
				</div>
				<span asp-validation-for="Password" class="text-danger small"></span>
			</div>
			<button type="submit" class="btn-auth">
				<i class="bi bi-box-arrow-in-right me-2"></i> Sign In
			</button>
			<hr class="my-3">
			<p class="text-center text-muted">veya</p>
			<a asp-controller="Account" asp-action="GoogleLogin" class="btn btn-outline-danger w-100">
				<i class="fab fa-google me-2"></i> Google ile Giriş Yap
			</a>
			<div class="d-flex justify-content-end mb-3">
				<a asp-controller="Account" asp-action="ConfirmMail" class="auth-link">Forgot password?</a>
			</div>
		}
	</div>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
	<script>
		function togglePassword() {
			const input = document.getElementById('passwordInput');
			const icon = document.getElementById('eyeIcon');
			if (input.type === 'password') {
				input.type = 'text';
				icon.classList.replace('bi-eye', 'bi-eye-slash');
			} else {
				input.type = 'password';
				icon.classList.replace('bi-eye-slash', 'bi-eye');
			}
		}
	</script>
</body>
</html>