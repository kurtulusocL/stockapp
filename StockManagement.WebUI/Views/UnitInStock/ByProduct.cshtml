@model IEnumerable<UnitInStockGetDto>
@{
	ViewData["Title"] = "Stock List";
	ViewData["Subtitle"] = "Manage your product stock";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-3">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<div>
			<h2 class="fw-bold mb-1">@ViewData["Title"]</h2>
			<p class="text-muted mb-0">@ViewData["Subtitle"]</p>
		</div>
		<a asp-controller="UnitInStock" asp-action="Index" class="btn btn-primary px-4">
			Stock List
		</a>
		<a asp-controller="UnitInStock" asp-action="WholeStocks" class="btn btn-primary px-4">
			All Stocks
		</a>
		<div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
			<span id="selectedCount" class="text-muted small"></span>
			<form asp-controller="UnitInStock" asp-action="DeleteMultiple" method="post" id="bulkDeleteForm"
				  onsubmit="return confirm('Are you sure you want to delete selected stocks?')">
				@Html.AntiForgeryToken()
				<div id="bulkDeleteIds"></div>
				<button type="submit" class="btn btn-sm btn-danger d-none" id="bulkDeleteBtn">
					<i class="bi bi-trash me-1"></i> Delete Selected
				</button>
			</form>
		</div>
	</div>
	<div class="card shadow-sm">
		<div class="card-body p-0">
			<div id="stockTableContainer">
				@await Html.PartialAsync("_StockTablePartial", Model)
			</div>
		</div>
	</div>
</div>