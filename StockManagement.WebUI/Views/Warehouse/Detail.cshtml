@model WarehouseGetDto
@{
	ViewData["Title"] = "Warehouse Detail";
	ViewData["Subtitle"] = "Manage your warehouse";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-3">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<div>
			<h2 class="fw-bold mb-1">@ViewData["Title"]</h2>
			<p class="text-muted mb-0">@ViewData["Subtitle"]</p>
		</div>
		<div>
			<a asp-controller="Warehouse" asp-action="WholeWarehouse" class="btn btn-info">
				Whole Warehouse
			</a>
			<a asp-controller="Warehouse" asp-action="Index" class="btn btn-outline-secondary me-2">
				<i class="bi bi-arrow-left me-1"></i> Back to Warehouse List
			</a>
			<a asp-controller="Warehouse" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
				<i class="bi bi-pencil me-1"></i> Edit
			</a>
		</div>
	</div>

	<div class="row g-4">
		<div class="col-md-8">
			<div class="card shadow-sm">
				<div class="card-header bg-white py-3">
					<h6 class="fw-bold mb-0">General Information</h6>
				</div>
				<div class="card-body">
					<dl class="row mb-0">
						<dt class="col-sm-3 text-muted fw-normal">Warehouse Name</dt>
						<dd class="col-sm-9 fw-semibold">@Model.Name</dd>

						<dt class="col-sm-3 text-muted fw-normal">Warehouse Code</dt>
						<dd class="col-sm-9">@Model.Code</dd>

						<dt class="col-sm-3 text-muted fw-normal">Warehouse Address</dt>
						<dd class="col-sm-9">@Model.Address</dd>

						<dt class="col-sm-3 text-muted fw-normal">Warehouse Type</dt>
						<dd class="col-sm-9">@Model.TypeOfWarehouse</dd>

						<dt class="col-sm-3 text-muted fw-normal">Product Count</dt>
						<dd class="col-sm-9">@Model.ProductCount</dd>

						<dt class="col-sm-3 text-muted fw-normal">Stock Count</dt>
						<dd class="col-sm-9">@Model.UnitInStockCount</dd>

						<dt class="col-sm-3 text-muted fw-normal">Status</dt>
						<dd class="col-sm-9">
							@if (Model.IsActive)
							{
								<span class="badge bg-success-subtle text-success px-3 py-2">Active</span>
							}
							else
							{
								<span class="badge bg-danger-subtle text-danger px-3 py-2">Inactive</span>
							}
							@if (Model.IsDeleted)
							{
								<span class="badge bg-success-subtle text-danger px-3 py-2">Deleted</span>
							}
							else
							{
								<span class="badge bg-danger-subtle text-success px-3 py-2">Not Deleted</span>
							}
						</dd>

						<dt class="col-sm-3 text-muted fw-normal">Created At</dt>
						<dd class="col-sm-9">@Model.CreatedDate.ToString("dd MMM yyyy, HH:mm")</dd>

						<dt class="col-sm-3 text-muted fw-normal">Updated At</dt>
						<dd class="col-sm-9">
							@(Model.UpdatedDate.HasValue? Model.UpdatedDate.Value.ToString("dd MMM yyyy, HH:mm") : "-")
						</dd>

						<dt class="col-sm-3 text-muted fw-normal">Suspended At</dt>
						<dd class="col-sm-9">
							@(Model.SuspendedDate.HasValue? Model.SuspendedDate.Value.ToString("dd MMM yyyy, HH:mm") : "-")
						</dd>

						<dt class="col-sm-3 text-muted fw-normal">Deleted At</dt>
						<dd class="col-sm-9">
							@(Model.DeletedDate.HasValue? Model.DeletedDate.Value.ToString("dd MMM yyyy, HH:mm") : "-")
						</dd>
					</dl>
				</div>
			</div>
		</div>

		<div class="col-md-4">
			<div class="card shadow-sm">
				<div class="card-header bg-white py-3">
					<h6 class="fw-bold mb-0">Actions</h6>
				</div>
				<div class="card-body d-grid gap-2">
					<a asp-controller="Warehouse" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">
						<i class="bi bi-pencil me-2"></i> Edit Category
					</a>
					<form asp-controller="Warehouse" asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete @Model.Name?')">
						@Html.AntiForgeryToken()
						<input type="hidden" name="id" value="@Model.Id" />
						<button type="submit" class="btn btn-outline-danger w-100">
							<i class="bi bi-trash me-2"></i> Delete Warehouse
						</button>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>
