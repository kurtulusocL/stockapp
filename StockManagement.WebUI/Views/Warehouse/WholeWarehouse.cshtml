@model IEnumerable<WarehouseGetDto>
@{
	ViewData["Title"] = "All Warehouse List";
	ViewData["Subtitle"] = "Manage your all warehouses";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-3">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<div>
			<h2 class="fw-bold mb-1">@ViewData["Title"]</h2>
			<p class="text-muted mb-0">@ViewData["Subtitle"]</p>
		</div>
		<a asp-controller="Warehouse" asp-action="Create" class="btn btn-primary px-4">
			<i class="bi bi-plus-lg me-1"></i> Add A New Warehouse
		</a>
		<a asp-controller="Warehouse" asp-action="Index" class="btn btn-primary px-4">
			Warehouse List
		</a>
		<div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
			<span id="selectedCount" class="text-muted small"></span>
			<form asp-controller="Warehouse" asp-action="DeleteMultiple" method="post" id="bulkDeleteForm" onsubmit="return confirm('Are you sure you want to delete selected warehouses?')">
				@Html.AntiForgeryToken()
				<div id="bulkDeleteIds"></div>
				<button type="submit" class="btn btn-sm btn-danger d-none" id="bulkDeleteBtn">
					<i class="bi bi-trash me-1"></i> Delete Selected
				</button>
			</form>
		</div>
	</div>
	<div class="card shadow-sm">
		<div class="card-body p-0">
			<div class="table-responsive">
				<table class="table table-hover align-middle mb-0">
					<thead class="table-light">
						<tr>
							<th class="ps-4">
								<input type="checkbox" id="selectAll" class="form-check-input" />
							</th>
							<th class="ps-4">#</th>
							<th>Name</th>
							<th>Code</th>
							<th>Address</th>
							<th>Type of Warehouse</th>
							<th>Counts</th>
							<th>Status</th>
							<th class="text-end pe-4">Actions</th>
						</tr>
					</thead>
					<tbody>
						@if (!Model.Any())
						{
							<tr>
								<td colspan="12" class="text-center py-5 text-muted">
									<i class="bi bi-inbox fs-3 d-block mb-2"></i>
									No warehouse found.
								</td>
							</tr>
						}
						else
						{
							int i = 1;
							foreach (var item in Model)
							{
								<tr>
									<td class="ps-4">
										<input type="checkbox" class="form-check-input row-checkbox" value="@item.Id" />
									</td>

									<td class="ps-4 text-muted">@i</td>
									<td class="fw-semibold">@item.Name</td>
									<td class="text-muted">@item.Code</td>
									<td class="text-muted">@item.Address</td>
									<td class="text-muted">@item.TypeOfWarehouse</td>
									<td class="text-muted">
										<ul>
											<li>Products: @item.ProductCount</li>
											<li>Stocks: @item.UnitInStockCount</li>
										</ul>
									</td>
									<td>
										@if (item.IsActive)
										{
											<span class="badge bg-success-subtle text-success px-3 py-2">Active</span>
											<form asp-controller="Warehouse" asp-action="SetInactive" method="post" class="d-inline">
												@Html.AntiForgeryToken()
												<input type="hidden" name="id" value="@item.Id" />
												<button type="submit" class="btn btn-sm btn-warning">Set Inactive</button>
											</form>
										}
										else
										{
											<span class="badge bg-danger-subtle text-danger px-3 py-2">Inactive</span>
											<form asp-controller="Warehouse" asp-action="SetActive" method="post" class="d-inline">
												@Html.AntiForgeryToken()
												<input type="hidden" name="id" value="@item.Id" />
												<button type="submit" class="btn btn-sm btn-warning">Set Active</button>
											</form>
										}
										@if (item.IsDeleted)
										{
											<span class="badge bg-success-subtle text-danger px-3 py-2">Deleted</span>
											<form asp-controller="Warehouse" asp-action="SetNotDeleted" method="post" class="d-inline">
												@Html.AntiForgeryToken()
												<input type="hidden" name="id" value="@item.Id" />
												<button type="submit" class="btn btn-sm btn-warning">Set Not Deleted</button>
											</form>
										}
										else
										{
											<span class="badge bg-danger-subtle text-success px-3 py-2">Not Deleted</span>
											<form asp-controller="Warehouse" asp-action="SetDeleted" method="post" class="d-inline">
												@Html.AntiForgeryToken()
												<input type="hidden" name="id" value="@item.Id" />
												<button type="submit" class="btn btn-sm btn-warning">Set Deleted</button>
											</form>
										}
									</td>
									<td class="text-end pe-4">
										<a asp-controller="Warehouse" asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1" title="Detail">
											<i class="bi bi-eye"></i>
										</a>
										<a asp-controller="Warehouse" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1" title="Edit">
											<i class="bi bi-pencil"></i>
										</a>
									</td>
								</tr>
								i++;
							}
						}
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>