@model StockMovementGetDto
@{
	ViewData["Title"] = "Stock Movement Detail";
	ViewData["Subtitle"] = "Manage your stock movements";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-3">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<div>
			<h2 class="fw-bold mb-1">@ViewData["Title"]</h2>
			<p class="text-muted mb-0">@ViewData["Subtitle"]</p>
		</div>
		<div>
			<a asp-controller="StockMovement" asp-action="WholeStockMovements" class="btn btn-info">
				Whole Stock Movements
			</a>
			<a asp-controller="StockMovement" asp-action="Index" class="btn btn-outline-secondary me-2">
				<i class="bi bi-arrow-left me-1"></i> Back to Stock Movement List
			</a>
		</div>
	</div>
	<form asp-controller="StockMovement" asp-action="ByRange" method="get" class="mb-3">
		<div class="card shadow-sm">
			<div class="card-body py-2">
				<div class="row g-2 align-items-end">
					<div class="col-auto">
						<label class="form-label small text-muted mb-1">Start Date</label>
						<input type="datetime-local" name="start" class="form-control form-control-sm" required />
					</div>
					<div class="col-auto">
						<label class="form-label small text-muted mb-1">End Date</label>
						<input type="datetime-local" name="end" class="form-control form-control-sm" required />
					</div>
					<div class="col-auto">
						<button type="submit" class="btn btn-primary btn-sm">
							<i class="bi bi-search me-1"></i> Search Movement
						</button>
					</div>
					<div class="col-auto">
						<a asp-action="Index" class="btn btn-outline-secondary btn-sm">
							<i class="bi bi-x-lg me-1"></i> Clear Form
						</a>
					</div>
				</div>
			</div>
		</div>
	</form>
	<hr />
	<div class="row g-4">
		<div class="col-md-8">
			<div class="card shadow-sm">
				<div class="card-header bg-white py-3">
					<h6 class="fw-bold mb-0">General Information</h6>
				</div>
				<div class="card-body">
					<dl class="row mb-0">
						<dt class="col-sm-3 text-muted fw-normal">Movement Type</dt>
						<dd class="col-sm-9 fw-semibold">@Model.MovementType</dd>

						<dt class="col-sm-3 text-muted fw-normal">Quantity</dt>
						<dd class="col-sm-9">@Model.Quantity</dd>

						<dt class="col-sm-3 text-muted fw-normal">Product Id</dt>
						<dd class="col-sm-9">
							@if (Model.ProductId != null)
							{
								<span>ProductId: @Model.ProductId</span>
							}
							else
							{
								<span class="badge badge-danger" style="color:black">??</span>
							}
						</dd>

						<dt class="col-sm-3 text-muted fw-normal">User Id</dt>
						<dd class="col-sm-9">@Model.AppUserId</dd>

						<dt class="col-sm-3 text-muted fw-normal">Status</dt>
						<dd class="col-sm-9">
							@if (Model.IsActive)
							{
								<span class="badge bg-success-subtle text-success px-3 py-2">Active</span>
							}
							else
							{
								<span class="badge bg-danger-subtle text-danger px-3 py-2">Inactive</span>
							}
							@if (Model.IsDeleted)
							{
								<span class="badge bg-success-subtle text-danger px-3 py-2">Deleted</span>
							}
							else
							{
								<span class="badge bg-danger-subtle text-success px-3 py-2">Not Deleted</span>
							}
						</dd>

						<dt class="col-sm-3 text-muted fw-normal">Created At</dt>
						<dd class="col-sm-9">@Model.CreatedDate.ToString("dd MMM yyyy, HH:mm")</dd>

						<dt class="col-sm-3 text-muted fw-normal">Updated At</dt>
						<dd class="col-sm-9">
							@(Model.UpdatedDate.HasValue? Model.UpdatedDate.Value.ToString("dd MMM yyyy, HH:mm") : "-")
						</dd>

						<dt class="col-sm-3 text-muted fw-normal">Suspended At</dt>
						<dd class="col-sm-9">
							@(Model.SuspendedDate.HasValue? Model.SuspendedDate.Value.ToString("dd MMM yyyy, HH:mm") : "-")
						</dd>

						<dt class="col-sm-3 text-muted fw-normal">Deleted At</dt>
						<dd class="col-sm-9">
							@(Model.DeletedDate.HasValue? Model.DeletedDate.Value.ToString("dd MMM yyyy, HH:mm") : "-")
						</dd>
					</dl>
				</div>
			</div>
		</div>

		<div class="col-md-4">
			<div class="card shadow-sm">
				<div class="card-header bg-white py-3">
					<h6 class="fw-bold mb-0">Actions</h6>
				</div>
				<div class="card-body d-grid gap-2">
					<form asp-controller="StockMovement" asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete movement')">
						@Html.AntiForgeryToken()
						<input type="hidden" name="id" value="@Model.Id" />
						<button type="submit" class="btn btn-outline-danger w-100">
							<i class="bi bi-trash me-2"></i> Delete Stock Movement
						</button>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>