@model IEnumerable<StockMovementGetDto>
@{
	ViewData["Title"] = "Stock Movement Analyze";
	ViewData["Subtitle"] = "See your stock movements range analyze results";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-3">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<div>
			<h2 class="fw-bold mb-1">@ViewData["Title"]</h2>
			<p class="text-muted mb-0">@ViewData["Subtitle"]</p>
		</div>
		<a asp-controller="StockMovement" asp-action="Index" class="btn btn-primary px-4">
			Stock Movement List
		</a>
		<a asp-controller="StockMovement" asp-action="WholeStockMovements" class="btn btn-primary px-4">
			All Stock Movements
		</a>
		<div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
			<span id="selectedCount" class="text-muted small"></span>
			<form asp-controller="StockMovement" asp-action="DeleteMultiple" method="post" id="bulkDeleteForm"
				  onsubmit="return confirm('Are you sure you want to delete selected stock movement?')">
				@Html.AntiForgeryToken()
				<div id="bulkDeleteIds"></div>
				<button type="submit" class="btn btn-sm btn-danger d-none" id="bulkDeleteBtn">
					<i class="bi bi-trash me-1"></i> Delete Selected
				</button>
			</form>
		</div>
	</div>
	<form asp-controller="StockMovement" asp-action="ByRange" method="get" class="mb-3">
		<div class="card shadow-sm">
			<div class="card-body py-2">
				<div class="row g-2 align-items-end">
					<div class="col-auto">
						<label class="form-label small text-muted mb-1">Start Date</label>
						<input type="datetime-local" name="start" class="form-control form-control-sm" required />
					</div>
					<div class="col-auto">
						<label class="form-label small text-muted mb-1">End Date</label>
						<input type="datetime-local" name="end" class="form-control form-control-sm" required />
					</div>
					<div class="col-auto">
						<button type="submit" class="btn btn-primary btn-sm">
							<i class="bi bi-search me-1"></i> Search Movement
						</button>
					</div>
					<div class="col-auto">
						<a asp-action="Index" class="btn btn-outline-secondary btn-sm">
							<i class="bi bi-x-lg me-1"></i> Clear Form
						</a>
					</div>
				</div>
			</div>
		</div>
	</form>
	<hr />
	<div class="card shadow-sm">
		<div class="card-body p-0">
			<div class="table-responsive">
				<table class="table table-hover align-middle mb-0">
					<thead class="table-light">
						<tr>
							<th class="ps-4">
								<input type="checkbox" id="selectAll" class="form-check-input" />
							</th>
							<th class="ps-4">#</th>
							<th>Product Info</th>
							<th>User Info</th>
							<th>Movement Type</th>
							<th>Quantity</th>
							<th>Status</th>
							<th class="text-end pe-4">Actions</th>
						</tr>
					</thead>
					<tbody>
						@if (!Model.Any())
						{
							<tr>
								<td colspan="12" class="text-center py-5 text-muted">
									<i class="bi bi-inbox fs-3 d-block mb-2"></i>
									No stock movement found.
								</td>
							</tr>
						}
						else
						{
							int i = 1;
							foreach (var item in Model)
							{
								<tr>
									<td class="ps-4">
										<input type="checkbox" class="form-check-input row-checkbox" value="@item.Id" />
									</td>

									<td class="ps-4 text-muted">@i</td>
									<td class="fw-semibold">
										@if (item.ProductId != null)
										{
											<span>ProductId: @item.ProductId</span>
											<br />
											<a asp-controller="StockMovement" asp-action="ByProduct" asp-route-id="@item.ProductId" class="btn btn-info btn-sm px-4">
												See for Product
											</a>
										}
										else
										{
											<span class="badge badge-danger" style="color:black">??</span>
										}
									</td>
									<td class="text-muted">
										UserId: @item.AppUserId
										<br />
										<a asp-controller="StockMovement" asp-action="ByUser" asp-route-id="@item.AppUserId" class="btn btn-info btn-sm px-4">
											See for User
										</a>
									</td>
									<td class="text-muted">@item.MovementType</td>
									<td class="text-muted">@item.Quantity</td>
									<td>
										@if (item.IsActive)
										{
											<span class="badge bg-success-subtle text-success px-3 py-2">Active</span>
											<form asp-controller="StockMovement" asp-action="SetInactive" method="post" class="d-inline">
												@Html.AntiForgeryToken()
												<input type="hidden" name="id" value="@item.Id" />
												<button type="submit" class="btn btn-sm btn-warning">Set Inactive</button>
											</form>
										}
										else
										{
											<span class="badge bg-danger-subtle text-danger px-3 py-2">Inactive</span>
											<form asp-controller="StockMovement" asp-action="SetActive" method="post" class="d-inline">
												@Html.AntiForgeryToken()
												<input type="hidden" name="id" value="@item.Id" />
												<button type="submit" class="btn btn-sm btn-warning">Set Active</button>
											</form>
										}
										@if (item.IsDeleted)
										{
											<span class="badge bg-success-subtle text-danger px-3 py-2">Deleted</span>
											<form asp-controller="StockMovement" asp-action="SetNotDeleted" method="post" class="d-inline">
												@Html.AntiForgeryToken()
												<input type="hidden" name="id" value="@item.Id" />
												<button type="submit" class="btn btn-sm btn-warning">Set Not Deleted</button>
											</form>
										}
										else
										{
											<span class="badge bg-danger-subtle text-success px-3 py-2">Not Deleted</span>
											<form asp-controller="StockMovement" asp-action="SetDeleted" method="post" class="d-inline">
												@Html.AntiForgeryToken()
												<input type="hidden" name="id" value="@item.Id" />
												<button type="submit" class="btn btn-sm btn-warning">Set Deleted</button>
											</form>
										}
									</td>
									<td class="text-end pe-4">
										<a asp-controller="StockMovement" asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1" title="Detail">
											<i class="bi bi-eye"></i>
										</a>
									</td>
								</tr>
								i++;
							}
						}
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>