@model IEnumerable<UnitInStockGetDto>
@{
    Layout = null;
}

<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th class="ps-4">
                    <input type="checkbox" id="selectAll" class="form-check-input" />
                </th>
                <th class="ps-4">#</th>
                <th>Product</th>
                <th>Warehouse</th>
                <th>Quantity</th>
                <th>Code</th>
                <th>User</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <input type="checkbox" class="form-check-input row-checkbox" value="@item.Id" />
                        </td>
                        <td class="ps-4">@item.Id</td>
                        <td>
                            @if (item.ProductId != null)
                            {
                                <span>ProductId: @item.ProductId</span>
                                <br />
                                <a asp-controller="UnitInStock" asp-action="ByProduct" asp-route-id="@item.ProductId" class="btn btn-sm btn-info">See Product Stocks</a>
                            }
                            else
                            {
                                <span class="badge badge-danger">??</span>
                            }
                        </td>
                        <td>
                            <span>WarehouseId: @item.WarehouseId</span>
                            <br />
                            <a asp-controller="UnitInStock" asp-action="ByWarehouse" asp-route-id="@item.WarehouseId" class="btn btn-sm btn-info">See Warehouse Stocks</a>
                        </td>
                        <td>@item.Quantity</td>
                        <td>@item.Code</td>
                        <td>
                            <span>AppUserId: @item.AppUserId</span>
                            <br />
                            <a asp-controller="UnitInStock" asp-action="ByUser" asp-route-id="@item.AppUserId" class="btn btn-sm btn-info">See User Stocks</a>
                        </td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success px-3 py-2">Active</span>
                                <form asp-controller="UnitInStock" asp-action="SetInactive" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-warning">Set Inactive</button>
                                </form>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger px-3 py-2">Inactive</span>
                                <form asp-controller="UnitInStock" asp-action="SetActive" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-warning">Set Active</button>
                                </form>
                            }
                            @if (item.IsDeleted)
                            {
                                <span class="badge bg-success-subtle text-danger px-3 py-2">Deleted</span>
                                <form asp-controller="UnitInStock" asp-action="SetNotDeleted" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-warning">Set Not Deleted</button>
                                </form>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-success px-3 py-2">Not Deleted</span>
                                <form asp-controller="UnitInStock" asp-action="SetDeleted" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-warning">Set Deleted</button>
                                </form>
                            }
                        </td>
                        <td>
                            <a asp-controller="UnitInStock" asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1" title="Detail">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-controller="UnitInStock" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center text-muted py-4">
                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                        No stock records found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>