@model IEnumerable<ProductGetDto>

<table class="table table-hover align-middle" id="productTable">
    <thead class="table-dark">
        <tr>
            <th><input type="checkbox" id="selectAll" /></th>
            <th>Image</th>
            <th>Name - Code</th>          
            <th>Price</th>
            <th>Category Info</th>
            <th>Warehouse Info</th>
            <th>User Info</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td><input type="checkbox" class="row-checkbox" value="@item.Id" /></td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="~/img/@item.ImageUrl" alt="@item.Name" width="50" height="50" class="rounded object-fit-cover" asp-append-version="true" />
                        }
                        else
                        {
                            <img src="~/img/statics/noImage.jpg" alt="@item.Name" width="50" height="50" class="rounded object-fit-cover" asp-append-version="true" />
                        }
                    </td>
                    <td>@item.Name, @item.Code</td>                  
                    <td>@item.Price.ToString("C")</td>
                    <td>@item.CategoryId</td>
                    <td>@item.WarehouseId</td>
                    <td>@item.AppUserId</td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge bg-success-subtle text-success px-3 py-2">Active</span>
                            <form asp-controller="Product" asp-action="SetInactive" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-warning">Set Inactive</button>
                            </form>
                        }
                        else
                        {
                            <span class="badge bg-danger-subtle text-danger px-3 py-2">Inactive</span>
                            <form asp-controller="Product" asp-action="SetActive" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-warning">Set Active</button>
                            </form>
                        }
                        @if (item.IsDeleted)
                        {
                            <span class="badge bg-success-subtle text-danger px-3 py-2">Deleted</span>
                            <form asp-controller="Product" asp-action="SetNotDeleted" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-warning">Set Not Deleted</button>
                            </form>
                        }
                        else
                        {
                            <span class="badge bg-danger-subtle text-success px-3 py-2">Not Deleted</span>
                            <form asp-controller="Product" asp-action="SetDeleted" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-warning">Set Deleted</button>
                            </form>
                        }
                    </td>
                    <td>
                        <a asp-controller="Product" asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-controller="Product" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-controller="Product" asp-action="AddStock" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                            <i class="bi bi-plus-circle"></i> Add Stock
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="9" class="text-center text-muted">No products found.</td>
            </tr>
        }
    </tbody>
</table>